#!/bin/bash
# plicc - compile and link PL/I source with Iron Spring in one command
# Copyright 2026 Ross Shkurat
# SPDX-License-Identifier: Apache-2.0

set -o nounset
set -o pipefail
# set -o errexit  # Optional; test carefully

PLIC="${PLIC:-plic}"
CCLD="${CCLD:-gcc}"
LDFLAGS="${LDFLAGS:--m32 -no-pie -z muldefs}"
LIBS="${LIBS:--lprf}"
CINTEROP_LIBS=(${CINTEROP_LIBS:-/usr/lib/pli/alt/fhs.o /usr/lib/pli/alt/ghs.o})  # Now array
PLIINC="${PLIINC:--i/usr/lib/pli/include -i/usr/local/include}"

usage() {
  cat >&2 <<'EOF'
PL/I Compiler Toolchain

Usage: plicc [options] <source.pli|.pl1>... [object.o|archive.a]...
  Compile PL/I source files and link into a Linux executable.

Options:
  --cinterop       Use when linking with externally compiled static libraries or object files
  --compile        Compile only, do not link
  --out <name>     Output executable name (default: basename of first .pli)
  --verbose        Show progress messages
  --help           Show this help and exit

Libraries prefixed with -l are passed directly to the linker. All other flags are passed through to the plic compiler.
EOF
  exit 1
}

die() { echo "plicc: error: $*" >&2; exit 1; }
say() { [ "$verbose" -eq 1 ] && echo "plicc: $*"; }

# --- Parse arguments ---
pli_files=() obj_files=() lib_files=() ld_libs=() cc_flags=()
exe_name="" cinterop=0 compile_only=0 verbose=0

while [ $# -gt 0 ]; do
  case "$1" in
    --help) usage ;;
    --cinterop) cinterop=1 ;;
    --compile) compile_only=1 ;;
    --verbose) verbose=1 ;;
    --out)
      [ $# -ge 2 ] || die "--out requires an argument"
      exe_name="$2"
      shift
      ;;
    *.pli|*.pl1)
      [ -f "$1" ] || die "source file not found: $1"
      pli_files+=("$1")
      ;;
    *.o|*.obj)
      [ -f "$1" ] || die "object file not found: $1"
      obj_files+=("$1")
      ;;
    *.a)
      [ -f "$1" ] || die "archive not found: $1"
      lib_files+=("$1")
      ;;
    -l) cc_flags+=("$1") ;;             # bare -l (plic listing default)
    -l*)                                # -l followed by listing chars or lib name
      suffix="${1#-l}"
      if [[ $suffix =~ ^[siaxgmovn]+$ ]]; then
        cc_flags+=("$1")                # plic listing flags (-lsx, -la, -lg, etc.)
      else
        ld_libs+=("$1")                 # linker libraries (-lnet, -lprf, etc.)
      fi
      ;;
    --) shift; cc_flags+=("$@"); break ;;
    [!-]*.*) die "unknown file type: $1 (expected .pli, .pl1, .o, .obj, or .a)" ;;
    *) cc_flags+=("$1") ;;
  esac
  shift
done

[ ${#pli_files[@]} -gt 0 ] || [ ${#obj_files[@]} -gt 0 ] || [ ${#lib_files[@]} -gt 0 ] || usage

# --- Compile ---
for pli in "${pli_files[@]+"${pli_files[@]}"}"; do
  base=$(basename "$pli" .pli)
  base=$(basename "$base" .pl1)
  obj="${base}.o"
  say "compiling $pli → $obj"
  $PLIC -C -dELF $PLIINC ${cc_flags[@]+"${cc_flags[@]}"} "$pli" -o "$obj" \
    || die "compilation failed: $pli"
  rm -f "${base}.lst"
  obj_files+=("$obj")
done

# --- Output name ---
if [ -z "$exe_name" ]; then
  if [ ${#pli_files[@]} -gt 0 ]; then
    exe_name=$(basename "${pli_files[0]}" .pli)
    exe_name=$(basename "$exe_name" .pl1)
  else
    exe_name="a.out"
  fi
fi

if [ "$compile_only" -eq 1 ]; then
  say "done (compile-only) - objects generated"
  exit 0
fi

# --- Link ---
link_inputs=("${obj_files[@]+"${obj_files[@]}"}")
link_inputs+=("${lib_files[@]+"${lib_files[@]}"}")

if [ "$cinterop" -eq 1 ]; then
  say "enabling C interop modules"
  link_inputs+=("${CINTEROP_LIBS[@]+"${CINTEROP_LIBS[@]}"}")
fi
link_inputs+=("${ld_libs[@]+"${ld_libs[@]}"}")

say "linking $exe_name"
# shellcheck disable=SC2086
$CCLD $LDFLAGS -o "$exe_name" ${link_inputs[@]+"${link_inputs[@]}"} $LIBS \
  || die "linking failed: $exe_name"

say "done - $exe_name"